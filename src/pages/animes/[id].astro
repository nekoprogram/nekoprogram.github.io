---
// src/pages/anime/[id].astro
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// 1. Le decimos a Astro qué páginas de anime existen en tu carpeta content
export async function getStaticPaths() {
  const animeEntries = await getCollection('anime');
  return animeEntries.map(entry => ({
    params: { id: entry.id }, // El 'id' coincide con el nombre de tu archivo .md
    props: { entry },
  }));
}

// 2. Recuperamos los datos del anime que el usuario ha clicado
const { entry } = Astro.props;
const { Content } = await render(entry); // Convierte el Markdown en HTML funcional
---

<Layout title={entry.data.title}>
  <article style="max-width: 800px; margin: 0 auto; padding: 20px;">
    <!-- Botón para volver al listado de animes -->
    <a href="/anime" style="display: inline-flex; align-items: center; text-decoration: none; color: #888; margin-bottom: 20px;">
      ← Back to Animes
    </a>

    <h1>{entry.data.title}</h1>
    
    {/* Pintamos las etiquetas del anime si las tiene configuradas */}
    {entry.data.tags && (
      <div class="tag-container" style="margin-bottom: 30px; display: flex; gap: 10px; flex-wrap: wrap;">
        {entry.data.tags.map((tag) => (
          <a href={`/tags/${tag}`} style="padding: 4px 8px; background: #222; border-radius: 4px; text-decoration: none; color: #eee; font-size: 0.9em;">
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Aquí se inyecta todo el texto que escribiste en tu Markdown -->
    <div class="markdown-content">
      <Content />
    </div>
  </article>
</Layout>
---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Not Found">
  <section class="error-container">
    <div class="glitch-wrapper">
      <h1 class="glitch" data-text="404">ERROR 404</h1>
    </div>
    
    <h3> NOT FOUND</h3>
    <p class="error-msg">Parece que me han transportado a un Isekai, pero olvidaron darme los superpoderes... y el mapa.</p>
    <p class="error-msg">Looks like I got Isekai'd, but they forgot to give me the cheat powers... and the map.</p>
    
   
    <a href="/" class="back-link" style="margin-top: 30px;">
    
      Regresar a la zona segura (Inicio)
    </a>
  </section>
</Layout>
<style>
  .error-container {
    text-align: center;
    max-width: 600px;
    margin: 0 auto; 
    padding: 0 10px;
    
    /* CONTROL DE ALTURA ABSOLUTO */
    display: flex;
    align-items: center;
    flex-direction: column;
    justify-content: center;
    min-height: 60vh; /* Ocupa el 60% de la pantalla para no empujar el footer hacia abajo */
    
    /* CANDADO ANTI-SCROLL TOTAL */
    overflow: hidden; 
    box-sizing: border-box;
  }

  /* Aseguramos que el contenedor de la animación no rompa nada */
  .glitch-wrapper {
    max-height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  /* Efecto glitch retro para el número 404 */
  .glitch {
    font-size: 6rem;
    font-weight: bold;
    color: #fff;
    position: relative;
    text-shadow: 0.05em 0 0 #00ffcc, -0.025em -0.05em 0 #ff0055,
      0.025em 0.05em 0 #00ffbb;
    animation: glitch 500s infinite;
    line-height: 1; 
    margin: 0;
  }

  h3 {
    color: #ff0055;
    text-shadow: 0 0 8px rgba(255, 0, 85, 0.5);
    letter-spacing: 2px;
    margin: 10px 0;
  }

  .error-msg {
    color: #888;
    font-size: 0.95rem; /* Un pelín más pequeño para que no ocupe tantas líneas en móvil */
    margin: 5px 0;
    max-width: 90%; /* Evita que el texto toque los bordes laterales */
  }
</style>
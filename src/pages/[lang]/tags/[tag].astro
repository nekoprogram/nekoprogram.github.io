---
// src/pages/[lang]/tags/[tag].astro
import Layout from '../../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const allAnimes = await getCollection('anime');

  // Juntamos todos los tags únicos de BLOG y ANIME en una sola lista sin duplicados
  const allTags = [
    ...allPosts.map((post) => post.data.tags || []).flat(),
    ...allAnimes.map((anime) => anime.data.tags || []).flat()
  ];
  const uniqueTags = [...new Set(allTags)];
  
  const languages = ['es', 'en', 'ja'];

  // Generamos la combinación de CADA idioma con CADA etiqueta única
  return languages.flatMap((lang) => {
    return uniqueTags.map((tag) => {
      // 1. Filtramos los posts por etiqueta Y por idioma
      const filteredPosts = allPosts.filter((post) => {
        const postLang = post.data.lang || 'en';
        return post.data.tags?.includes(tag) && postLang === lang;
      });
      const sortedPosts = filteredPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

      // 2. Filtramos los animes por etiqueta Y por idioma (con salvavidas si no tienen lang)
      const filteredAnimes = allAnimes.filter((anime) => {
        const animeLang = anime.data.lang;
        const matchesTag = anime.data.tags?.includes(tag);
        if (animeLang) {
          return matchesTag && animeLang === lang;
        }
        return matchesTag && (lang === 'es' || lang === 'en');
      });

      return {
        params: { 
          lang, // <-- ¡OBLIGATORIO! Ahora Astro no se quejará jamás
          tag 
        },
        props: { 
          posts: sortedPosts,
          animes: filteredAnimes
        },
      };
    });
  });
}

// Interfaces de tipado para dejar a TypeScript feliz
interface Props {
  posts: CollectionEntry<'blog'>[];
  animes: CollectionEntry<'anime'>[];
}

const { tag, lang } = Astro.params;
const { posts, animes } = Astro.props as Props;

// Traducciones básicas de la interfaz
const ui = {
    es: { back: "Volver al inicio", found: `Se encontraron ${posts.length} artículo(s) y ${animes.length} anime(s).`, blog: "Artículos del Blog", format: "es-ES" },
    en: { back: "Back to Home", found: `Found ${posts.length} article(s) and ${animes.length} anime(s).`, blog: "Blog Articles", format: "en-US" },
    ja: { back: "ホームに戻る", found: `${posts.length}個の記事と${animes.length}個のアニメが見つかりました。`, blog: "ブログ記事", format: "ja-JP" }
};
const t = ui[lang as keyof typeof ui] || ui.en;
---

<Layout title={`Content labeled with #${tag}`}>
  <article>
    <a href={`/${lang}/`} class="back-link">
      <svg style="width: 16px; height: 16px; vertical-align: middle; margin-right: 5px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      {t.back}
    </a>

    <h2> <span class="highlight">#{tag}</span></h2>
    <p style="color: #888; margin-bottom: 30px;">
      {t.found}
    </p>

    {posts.length > 0 && (
      <h3>{t.blog}</h3>
      <ul style="margin-bottom: 30px;">
        {posts.map(post => (
          <li style="margin-bottom: 15px;">
            {/* Rutas de enlaces adaptadas a /lang/blog/id */}
            <a href={`/${lang}/blog/${post.id}`}>{post.data.title}</a>
            <span style="font-size: 0.8em; color: #888; display: block; margin-bottom: 4px;">
              {post.data.date.toLocaleDateString(t.format, { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
            <div class="tag-container">
              {post.data.tags.map((tStr: string) => (
                <a href={`/${lang}/tags/${tStr}`} class={`tag ${tStr === tag ? 'active' : ''}`}>#{tStr}</a>
              ))}
            </div>
          </li>
        ))}
      </ul>
    )}

    {animes.length > 0 && (
      <h3>Animes</h3>
      <ul>
        {animes.map(anime => (
          <li style="margin-bottom: 15px;">
            {/* Rutas de enlaces adaptadas a /lang/animes/id */}
            <a href={`/${lang}/animes/${anime.id}`}>{anime.data.title}</a>
            <div class="tag-container" style="margin-top: 4px;">
              {anime.data.tags.map((tStr: string) => (
                <a href={`/${lang}/tags/${tStr}`} class={`tag ${tStr === tag ? 'active' : ''}`}>#{tStr}</a>
              ))}
            </div>
          </li>
        ))}
      </ul>
    )}
  </article>
</Layout>
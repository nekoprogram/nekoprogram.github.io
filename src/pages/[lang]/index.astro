---
// src/pages/[lang]/index.astro
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

// 1. Le decimos a Astro que esta página existe para los 3 idiomas
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;

// 2. Traemos todos los posts de la colección 'blog'
const posts = await getCollection("blog");

// 3. FILTRAMOS por el idioma de la URL y ordenamos por fecha
const filteredPosts = posts
    .filter(post => {
        const postLang = post.data.lang || 'en';
        return postLang === lang;
    })
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 4. Corregimos la importación del SVG usando la nueva ruta relativa por la profundidad
import IconoNostr from "../../../public/gemini-svg.svg";

// 5. Traducciones de los textos sueltos de tu página de inicio
const ui = {
    es: {
        blogTitle: "Publicaciones del Blog",
        noPosts: "No hay publicaciones aún...",
        more: "Ver más",
        welcome: "Bienvenido a mi Github.io",
        favAnime: "Animes Favoritos",
        seeAnime: "Ver página de animes",
        aboutMe: "Sobre Mí",
        dateFormat: "es-ES",
        contentwithTag:"Contenido(s) con etiqueta(s)"
    },
    en: {
        blogTitle: "Blog Posts",
        noPosts: "No posts yet...",
        more: "More",
        welcome: "Welcome to my Github.io",
        favAnime: "Favorite Animes",
        seeAnime: "See animes page",
        aboutMe: "About Me",
        dateFormat: "en-US",
        contentwithTag:"Content(s) with Tag(s)"
    },
    ja: {
        blogTitle: "ブログ記事",
        noPosts: "まだ投稿はありません...",
        more: "もっと見る",
        welcome: "Github.io ページへようこそ",
        favAnime: "お気に入りのアニメ",
        seeAnime: "アニメページを見る",
        aboutMe: "私について",
        dateFormat: "ja-JP",
        contentwithTag:"タグが付いたコンテンツ"
    }
};

const t = ui[lang as keyof typeof ui] || ui.en;
---

<Layout>
    <section id="index-section">
        <div id="blog-section">
            <h3 style="margin-top: 20px;">{t.blogTitle}</h3>
            <ul>
                {
                    filteredPosts.length === 0 ? (
                        <li style="color: #888; list-style: none; padding-left: 0;">
                            {t.noPosts}
                        </li>
                    ) : (
                        // Usamos filteredPosts en lugar de sortedPosts
                        filteredPosts.slice(0, 5).map((post) => (
                            <li style="margin-bottom: 15px;">
                                {/* Enlace corregido: Ahora incluye el idioma actual */}
                                <a href={`/${lang}/blog/${post.id}`}>
                                    {post.data.title}
                                </a>
                                <span style="font-size: 0.8em; color: #888; display: block; margin-bottom: 4px;">
                                    {post.data.date.toLocaleDateString(
                                        t.dateFormat, // Formato de fecha según idioma
                                        {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        },
                                    )}
                                </span>

                                <div class="tag-container">
                                    {post.data.tags.map((tag) => (
                                        // Enlace a tags corregido
                                        <a href={`/${lang}/tags/${tag}`} class="tag">
                                            #{tag}
                                        </a>
                                    ))}
                                </div>
                            </li>
                        ))
                    )
                }
            </ul>
            {/* Enlace de "More" corregido */}
            <a href={`/${lang}/blog`}>{t.more}</a>
        </div>
        <section id="links">
            <div id="text">
                <h3>{t.welcome} <a style="color:white;" href="https://github.com/nekoprogram" target="_blank"><Icon name="simple-icons:github"></Icon></a></h3>
                <i>A cyber cat Nyan &gt;.&lt;</i>
                {/* Enlace de "About Me" corregido */}
                <a href={`/${lang}/about`}>{t.aboutMe}</a>
                <h3>Links</h3>
                <ul>
                    <li>
                        <a
                            href="https://misskey.social/@Mekoprogram"
                            target="_blank"
                        >
                            <Icon
                                name="simple-icons:misskey"
                                style="width: 20px; vertical-align: middle; margin-right: 5px;"
                            />
                            Misskey
                        </a>
                    </li>
                    <li>
                        <a
                            href="https://dill.burggit.moe/@nekoprogram"
                            target="_blank"
                        >
                            <Icon
                                name="simple-icons:misskey"
                                style="width: 20px; vertical-align: middle; margin-right: 5px;"
                            />
                            Burggit (Alt. Misskey Fork of Misskey)
                        </a>
                    </li>
                    <li>
                        <a href="https://tkz.one/@nekoprogram" target="_blank">
                            <Icon
                                name="simple-icons:mastodon"
                                style="width: 20px; vertical-align: middle; margin-right: 5px;"
                            />
                            Mastodon (Spanish Only)
                        </a>
                    </li>
                    <li>
                        <a
                            href="https://bsky.app/profile/did:plc:osxkkjbh7ownrbtkoo2lqlmf"
                            target="_blank"
                        >
                            <Icon
                                name="simple-icons:bluesky"
                                style="width: 20px; vertical-align: middle; margin-right: 5px;"
                            />
                            Bluesky
                        </a>
                    </li>
                    <li>
                        <a
                            href="https://primal.net/p/nprofile1qqsrwj4q6yzk66rtkdpkvnd9ssvfg4zmemdqte8qeqr4x35t75kf30sxr73pg"
                            target="_blank"
                        >
                            <IconoNostr
                                width="24"
                                height="24"
                                class="mi-clase-nostr"
                                color={"#d66060"}
                            />Nostr
                        </a>
                    </li>
                </ul>
            </div>
            <section>
                <h3>{t.favAnime}</h3>
                {/* Enlace de la página de animes corregido */}
                <p><a href={`/${lang}/animes`}>{t.seeAnime}</a></p>
            </section>
        </section>
    </section>
</Layout>
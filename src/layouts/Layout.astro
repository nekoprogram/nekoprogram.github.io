---
// src/layouts/Layout.astro
import "../styles/styles.css";
import { ClientRouter } from "astro:transitions";
import ScrollTopButton from "../components/ScrollTop.astro";

const currentYear = new Date().getFullYear();

// 1. Detectamos el idioma actual de la URL automáticamente gracias a Astro
const lang = Astro.currentLocale || "en"; 

// 2. Definimos los textos para cada idioma
const translations = {
    en: {
        nostr: "I can't use nekoweb to verify me in nostr. Verification in nostr is using this github.io page.",
        mainSite: "Main website:",
        rights: "All rights reserved.",
        copyrightNotice: "All anime images belong to their respective owners and copyright holders and are used for informational and fan-related purposes only.",
        alsoIn: "Also in"
    },
    es: {
        nostr: "No puedo usar nekoweb para verificarme en nostr. La verificación en nostr usa esta página de github.io.",
        mainSite: "Sitio web principal:",
        rights: "Todos los derechos reservados.",
        copyrightNotice: "Todas las imágenes de anime pertenecen a sus respectivos dueños y titulares de derechos de autor y se utilizan únicamente con fines informativos y relacionados con fans.",
        alsoIn:"También en"
    },
    ja: {
        nostr: "Nostrでの認証にnekowebが使えないため、このgithub.ioページを使用しています。",
        mainSite: "メインウェブサイト:",
        rights: "All rights reserved.",
        copyrightNotice: "すべてのアニメ画像はそれぞれの所有者および著作権者に帰属し、情報提供およびファン関連の目的のみに使用されます。",
        alsoIn:"また、"
    }
};

// 3. Elegimos el texto correcto según el idioma actual
const t = translations[lang as keyof typeof translations] || translations.en;
---

<!doctype html>
<!-- Cambiamos lang="es" por el idioma dinámico -->
<html>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Nekoprogram GitHub Page</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap"
            rel="stylesheet"
        />

        <link
            rel="shortcut icon"
            href="/img/nekoprogram.jpeg"
            type="image/x-icon"
        />

        <link href="https://nekoprogram.nekoweb.org/" rel="me" />
        <link href="https://nekoprogram.neocities.org/" rel="me" />
        <link href="https://misskey.social/@Mekoprogram" rel="me" />
        <link href="https://tkz.one/@nekoprogram" rel="me" />
        <link href="https://dill.burggit.moe/@nekoprogram" rel="me" />

        <ClientRouter />
    </head>
    <body>
        <main class="share-tech-mono-regular">
            <header>
                <div id="title-container">
                    <h1>Nekoprogram</h1>
                    <h4>GitHub.io Page</h4>
                    <p style="font-size: 0.8em; color: #ebcdf8;">
                        {t.nostr} <!-- Texto dinámico -->
                    </p>
                    <p class="main-site-notice">
                        {t.mainSite} <a
                            id="nekoweb-link"
                            href="https://nekoprogram.nekoweb.org"
                            target="_blank"
                            rel="noopener noreferrer"
                            >nekoprogram.nekoweb.org 🌐</a
                        >
                        {t.alsoIn} <a
                            id="neocities-link"
                            href="https://nekoprogram.neocities.org"
                            target="_blank"
                            rel="noopener noreferrer"
                            >nekoprogram.neocities.org 🌐</a
                        >
                    </p>
                </div>

                <img
                    src="/img/nekoprogram.jpeg"
                    alt="My image. A girl with a pink Kigurumi with a soda in front on her computer. The girl is from Needy Girl Overdose named Ame-chan or K-Angel"
                />
            </header>

            <slot />
           
            <footer>
                <p>
                    &copy; Nekoprogram <span>{currentYear} {t.rights}</span> <!-- Texto dinámico -->
                </p>
                <p>
                    {t.copyrightNotice} <!-- Texto dinámico -->
                </p>
            </footer>
        </main>
         <ScrollTopButton />
    </body>
</html>